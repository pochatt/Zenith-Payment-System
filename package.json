{
  "name": "zenith-mock",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply zenith-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply zenith-db --remote",
    "db:seed": "wrangler d1 execute zenith-db --local --command \"SELECT 1\"",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "@types/better-sqlite3": "^7.6.12",
    "better-sqlite3": "^11.9.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9",
    "wrangler": "^4.76.0"
  }
}
