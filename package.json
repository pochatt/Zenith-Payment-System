{
  "name": "zenith-mock",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply zenith-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply zenith-db --remote",
    "db:seed": "wrangler d1 execute zenith-db --local --command \"SELECT 1\"",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "typescript": "^5.6.3",
    "wrangler": "^4.76.0"
  }
}
