name = "zenith-mock"
main = "src/index.ts"
compatibility_date = "2024-12-01"
compatibility_flags = ["nodejs_compat"]

[vars]
ZC_HMAC_SECRET   = "zenith-dev-secret-change-in-prod"
BANK_BASE_URL    = ""   # same-Worker呼び出し。空文字 = 内部ルーティング
CRON_SECRET      = "zenith-cron-secret"
QR_SECRET        = "zenith-qr-secret-change-in-prod"

# D1 database
# `wrangler d1 create zenith-db` を実行後、出力された database_id を貼り付ける
[[d1_databases]]
binding       = "DB"
database_name = "zenith-db"
database_id   = "YOUR_DATABASE_ID"

# Cloudflare Queues
[[queues.producers]]
binding = "QUEUE"
queue   = "zenith-mock-queue"

[[queues.consumers]]
queue             = "zenith-mock-queue"
max_batch_size    = 10
max_batch_timeout = 5
max_retries       = 3

# R2 bucket（証跡・Vault の将来拡張用）
[[r2_buckets]]
binding     = "R2"
bucket_name = "zenith-mock-r2"

# KV for Mojaloop-style ALS caching（オプション。省略時は D1 にフォールバック）
# `wrangler kv namespace create "als-cache"` を実行後、出力された id を貼り付ける
# [[kv_namespaces]]
# binding = "ALS_KV"
# id      = "YOUR_KV_NAMESPACE_ID"

# Durable Objects（LimitDO: H-limit管理、StreamDO: Rafikiストリーミング）
[durable_objects]
bindings = [
  { name = "LIMIT_DO", class_name = "LimitDO" },
  { name = "STREAM_DO", class_name = "StreamDO" },
]

[[migrations]]
tag         = "v1"
new_sqlite_classes = ["LimitDO", "StreamDO"]

# Cron triggers
[triggers]
crons = [
  "30 7 * * *",   # 毎日 16:30 JST = 07:30 UTC → EOD
  "* * * * *",    # 毎分 → timeout sweep
]
